# placeintel — copy to `.env` and fill in. Nothing here is committed (.env is gitignored).
# All keys are optional individually, but you need at least one Gemini key.

# Gemini via Google official (recommended for EMBEDDING — true batch, fast).
# Get one at https://aistudio.google.com/apikey  (starts with "AIza")
GOOGLE_API_KEY=

# Gemini via a cheaper OpenAI/Gemini-compatible gateway (used for REASONING).
# Any gateway that speaks the Gemini /v1beta API works; key starts with "sk-".
# Optional override if your gateway isn't api.vectorengine.ai:
# VECTORENGINE_BASE_URL=https://api.vectorengine.ai
VECTORENGINE_API_KEY=

# SerpAPI — optional. Only used as a fallback when the free scrapers can't run.
# Get one at https://serpapi.com  (~1 credit / 20 reviews)
SERPAPI_API_KEY=

# --- Optional behaviour knobs (sensible defaults; uncomment to override) -------
# PLACEINTEL_REASON_MODEL=gemini-2.5-flash      # default reasoning model
# PLACEINTEL_EMBED_MODEL=gemini-embedding-2-preview
# PLACEINTEL_EMBED_DIMS=768
# PLACEINTEL_PLACE_TTL_DAYS=14                   # cached place details staleness
# PLACEINTEL_EVIDENCE_LANG=report               # "report" = translate quotes; "original" = verbatim
# PLACEINTEL_DATA_DIR=./data
